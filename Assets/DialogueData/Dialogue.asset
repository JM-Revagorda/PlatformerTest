  m_Script: {fileID: 11500000, guid: 97a65e5c2ca781145a017431692d5472, type: 3}
  m_Name: Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueObject
  dialogue:
  - "It\u2019s been a while since I came back here.\nStill as cold as ever."
  - This place used to be more alive.
  - "And I figured I\u2019d visit my friend."
  - 'He said he moved up the mountain.

    Not the easiest place to live.'
  - "Haven\u2019t heard from him in a long time.\nSo I thought I\u2019d check for
    myself."
  - "I\u2019ll pass through the city first\u2026"
  - then head up the mountain.
  - "Let\u2019s see how he's doing."
  - "I\u2019m coming."
